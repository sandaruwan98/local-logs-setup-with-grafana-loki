{
  "title": "Service Logs",
  "uid": "service-logs",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "includeAll": true,
        "allValue": ".+",
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(severity)",
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "correlationId",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log Volume",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "interval": "1m",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 100,
            "lineWidth": 0,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (severity) (count_over_time({service=~\"$service\", severity=~\"$severity\"} [$__interval]))",
          "refId": "A",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", severity=~\"$severity\"} |~ \"$correlationId\" | json | __error__=\"\" | line_format \"{{.message}}\"",
          "refId": "A"
        }
      ]
    }
  ]
}
